{% form_theme form 'bootstrap_5_layout.html.twig' %}

{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-md-6">
            {{ form_row(form.fullName) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.cpf) }}
        </div>
    </div>

    <fieldset class="mt-4">
        <legend>Vínculo Institucional (opcional)</legend>
        <p class="text-muted small">Preencha apenas se desejar vincular a pessoa a uma organização neste momento.</p>
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.organization) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.role) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.startDate) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.status) }}
            </div>
        </div>
    </fieldset>

    <div class="mt-4 d-flex gap-2">
        <button class="btn btn-primary">{{ button_label|default('Salvar') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('admin_person_index') }}">Voltar</a>
    </div>
{{ form_end(form) }}