{% extends 'admin/layout.html.twig' %}

{% block title %}Detalhes da pessoa{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">{{ person.fullName }}</h1>
            <p class="text-body-secondary mb-0">CPF: {{ person.cpf }}</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" href="{{ path('admin_person_edit', {'id': person.id}) }}">Editar</a>
            <a class="btn btn-outline-primary" href="{{ path('admin_person_index') }}">Voltar</a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">Dados pessoais</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Nome Completo</dt>
                        <dd class="col-sm-8">{{ person.fullName ?: 'Não informado' }}</dd>
                        <dt class="col-sm-4">CPF</dt>
                        <dd class="col-sm-8">{{ person.cpf ?: 'Não informado' }}</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body">
                    <h2 class="h5">Informações do sistema</h2>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Criada em</dt>
                        <dd class="col-sm-8">{{ person.createdAt ? person.createdAt|date('d/m/Y H:i') : 'Não informado' }}</dd>
                        <dt class="col-sm-4">Atualizada em</dt>
                        <dd class="col-sm-8">{{ person.updatedAt ? person.updatedAt|date('d/m/Y H:i') : 'Ainda não atualizada' }}</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3 gap-3">
                        <div>
                            <h2 class="h5 mb-1">Vínculos Institucionais</h2>
                            <p class="text-body-secondary mb-0">Gerencie os vínculos desta pessoa com organizações e seus papéis.</p>
                        </div>
                        <a class="btn btn-primary" href="{{ path('admin_person_add_organization', {'id': person.id}) }}">Adicionar vínculo institucional</a>
                    </div>

                    {% if personOrganizations is empty %}
                        <p class="text-body-secondary mb-0">Esta pessoa ainda não possui vínculos institucionais.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Organização</th>
                                        <th>Tipo</th>
                                        <th>Papéis</th>
                                        <th>Data de início</th>
                                        <th>Data de fim</th>
                                        <th>Status</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for relationship in personOrganizations %}
                                        <tr class="{{ relationship.endDate ? '' : 'table-success' }}">
                                            <td>{{ relationship.organization ? relationship.organization.legalName : 'Não informado' }}</td>
                                            <td>{{ relationship.organization and relationship.organization.organizationType ? relationship.organization.organizationType.name : 'Não informado' }}</td>
                                            <td>
                                                {% set roleNames = [] %}
                                                {% for relationRole in relationship.personOrganizationRoles %}
                                                    {% if relationRole.role %}
                                                        {% set roleNames = roleNames|merge([relationRole.role.name]) %}
                                                    {% endif %}
                                                {% endfor %}
                                                {{ roleNames|join(', ') ?: 'Sem papéis' }}
                                            </td>
                                            <td>{{ relationship.startDate ? relationship.startDate|date('d/m/Y') : '-' }}</td>
                                            <td>{{ relationship.endDate ? relationship.endDate|date('d/m/Y') : '-' }}</td>
                                            <td>
                                                {% if not relationship.endDate %}
                                                    <span class="badge bg-success">Ativo</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Encerrado</span>
                                                {% endif %}
                                            </td>
                                            <td class="text-nowrap">
                                                <div class="d-flex flex-wrap gap-2">
                                                    <a class="btn btn-sm btn-outline-secondary" href="{{ path('admin_person_organization_edit', {'id': relationship.id}) }}">Editar vínculo</a>
                                                    {% if not relationship.endDate %}
                                                        <form method="post" action="{{ path('admin_person_organization_close', {'id': relationship.id}) }}" class="d-inline" onsubmit="return confirm('Encerrar vínculo institucional?');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('close_person_organization' ~ relationship.id) }}">
                                                            <button class="btn btn-sm btn-outline-warning">Encerrar vínculo</button>
                                                        </form>
                                                    {% endif %}
                                                    <form method="post" action="{{ path('admin_person_organization_delete', {'id': relationship.id}) }}" class="d-inline" onsubmit="return confirm('Excluir vínculo institucional? Esta ação é irreversível.');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_person_organization' ~ relationship.id) }}">
                                                        <button class="btn btn-sm btn-outline-danger">Excluir vínculo</button>
                                                    </form>
                                                    <a class="btn btn-sm btn-outline-primary" href="{{ path('admin_person_organization_roles', {'id': relationship.id}) }}">Gerenciar papéis</a>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}