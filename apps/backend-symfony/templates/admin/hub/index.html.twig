{% extends 'admin/layout.html.twig' %}

{% block title %}Central SIGI{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Central SIGI</h1>
            <p class="text-body-secondary mb-0">Painel inicial de operacao do ecossistema Sertao Digital.</p>
        </div>
        <a class="btn btn-primary" href="{{ path('admin_attendance_index') }}">
            <twig:ux:icon name="tabler:list"/> Ver protocolos
        </a>
    </div>

    <div class="row g-3 mb-4">
        {% set kpis = [
            {'label': 'Atendimentos hoje', 'value': attendance.today, 'class': 'bg-light'},
            {'label': 'Protocolos hoje', 'value': attendance.today, 'class': 'bg-light'},
            {'label': 'Pendencias', 'value': attendance.pending, 'class': 'bg-warning'},
            {'label': 'Resolvidos', 'value': attendance.resolved, 'class': 'bg-success text-white'},
            {'label': 'Prioridade alta', 'value': attendance.highPriority, 'class': 'bg-danger text-white'}
        ] %}

        {% for kpi in kpis %}
            <div class="col-md-4 col-lg">
                <div class="card {{ kpi.class }}">
                    <div class="card-body p-3">
                        <h2 class="h6 text-uppercase small mb-1">{{ kpi.label }}</h2>
                        <p class="fs-3 mb-0">{{ kpi.value }}</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header">Atalhos internos</div>
                <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="{{ path('admin_attendance_dashboard') }}">
                        Dashboard SIGI
                        <twig:ux:icon name="tabler:arrow-right"/>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="{{ path('admin_attendance_index') }}">
                        Lista de protocolos
                        <twig:ux:icon name="tabler:arrow-right"/>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="{{ path('admin_chatwoot_event_index') }}">
                        Eventos Chatwoot
                        <twig:ux:icon name="tabler:arrow-right"/>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="{{ path('admin_attendance_settings') }}">
                        Configuracao de protocolos
                        <twig:ux:icon name="tabler:arrow-right"/>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-header">Ferramentas do ecossistema</div>
                <div class="list-group list-group-flush">
                    {% for label, url in hubLinks %}
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" href="{{ url }}" target="_blank" rel="noopener noreferrer">
                            {{ label }}
                            <twig:ux:icon name="tabler:arrow-right"/>
                        </a>
                    {% else %}
                        <div class="list-group-item text-body-secondary">
                            Configure as URLs SIGI_* no ambiente para exibir links externos.
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block sidebar %}{% endblock %}
