{% extends 'admin/layout.html.twig' %}

{% block title %}Protocolos e Atendimentos{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Protocolos e Atendimentos</h1>
            <p class="text-body-secondary mb-0">Conversas sincronizadas do Chatwoot com protocolo SIGI.</p>
        </div>
        <a class="btn btn-outline-primary" href="{{ path('admin_attendance_dashboard') }}">Dashboard</a>
    </div>

    <form class="card mb-4" method="get">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-2">
                    <label class="form-label" for="from">De</label>
                    <input class="form-control" id="from" name="from" type="date" value="{{ filters.from }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="to">Ate</label>
                    <input class="form-control" id="to" name="to" type="date" value="{{ filters.to }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="channel">Canal</label>
                    <select class="form-select" id="channel" name="channel">
                        <option value="">Todos</option>
                        {% for item in channels %}
                            <option value="{{ item }}" {{ filters.channel == item ? 'selected' }}>{{ item }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="status">Status</label>
                    <select class="form-select" id="status" name="status">
                        <option value="">Todos</option>
                        {% for item in statuses %}
                            <option value="{{ item }}" {{ filters.status == item ? 'selected' }}>{{ item }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="team">Time</label>
                    <select class="form-select" id="team" name="team">
                        <option value="">Todos</option>
                        {% for item in teams %}
                            <option value="{{ item }}" {{ filters.team == item ? 'selected' }}>{{ item }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label" for="priority">Prioridade</label>
                    <select class="form-select" id="priority" name="priority">
                        <option value="">Todas</option>
                        {% for item in priorities %}
                            <option value="{{ item }}" {{ filters.priority == item ? 'selected' }}>{{ item }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label" for="label">Etiqueta</label>
                    <input class="form-control" id="label" name="label" value="{{ filters.label }}" placeholder="Buscar etiqueta">
                </div>
                <div class="col-md-8 d-flex align-items-end gap-2">
                    <button class="btn btn-primary" type="submit"><twig:ux:icon name="tabler:search"/> Filtrar</button>
                    <a class="btn btn-outline-secondary" href="{{ path('admin_attendance_index') }}">Limpar</a>
                </div>
            </div>
        </div>
    </form>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Protocolo</th>
                        <th>Assunto</th>
                        <th>Contato</th>
                        <th>Pessoa SIGI</th>
                        <th>Canal</th>
                        <th>Status</th>
                        <th>Etiquetas</th>
                        <th>Time</th>
                        <th>Agente</th>
                        <th>Entrada</th>
                        <th>Atualizacao</th>
                        <th>Mensagem</th>
                        <th class="text-end">Acoes</th>
                    </tr>
                </thead>
                <tbody>
                    {% for protocol in paginator.results %}
                        <tr>
                            <td><strong>{{ protocol.protocolCode }}</strong></td>
                            <td>{{ protocol.subject ?: '-' }}</td>
                            <td>
                                {{ protocol.contactName ?: '-' }}
                                {% if protocol.contactHandle %}
                                    <div class="small text-body-secondary">{{ protocol.contactHandle }}</div>
                                {% endif %}
                            </td>
                            <td>
                                {% if protocol.person %}
                                    <a href="{{ path('admin_person_show', {'id': protocol.person.id}) }}">{{ protocol.person.fullName }}</a>
                                    <div class="small text-body-secondary">{{ protocol.person.personType }}</div>
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{{ protocol.sourceChannel ?: '-' }}</td>
                            <td>{{ protocol.status ?: '-' }}</td>
                            <td>
                                {% for label in protocol.labels %}
                                    <span class="badge text-bg-secondary">{{ label }}</span>
                                {% else %}
                                    -
                                {% endfor %}
                            </td>
                            <td>{{ protocol.responsibleTeam ?: '-' }}</td>
                            <td>{{ protocol.responsibleAgent ?: '-' }}</td>
                            <td>{{ protocol.createdAt ? protocol.createdAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>{{ protocol.updatedAt ? protocol.updatedAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>
                                {% if protocol.customerProtocolMessageSent %}
                                    <span class="badge text-bg-success">Enviada</span>
                                {% else %}
                                    <span class="badge text-bg-secondary">Pendente</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% set chatwootUrl = chatwootRuntimeConfig.conversationUrl(protocol.chatwootConversationId) %}
                                {% if chatwootUrl %}
                                    <a class="btn btn-sm btn-outline-primary" href="{{ chatwootUrl }}" target="_blank" rel="noopener noreferrer">Abrir no Chatwoot</a>
                                {% else %}
                                    <span class="text-body-secondary small">URL nao configurada</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="13" class="text-center text-body-secondary">Nenhum atendimento sincronizado.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% if paginator.hasToPaginate %}
        <nav class="mt-3" aria-label="Paginacao">
            <ul class="pagination">
                <li class="page-item {{ not paginator.hasPreviousPage ? 'disabled' }}">
                    <a class="page-link" href="{{ path('admin_attendance_index', app.request.query.all|merge({'page': paginator.previousPage})) }}">Anterior</a>
                </li>
                <li class="page-item disabled"><span class="page-link">{{ paginator.currentPage }} / {{ paginator.lastPage }}</span></li>
                <li class="page-item {{ not paginator.hasNextPage ? 'disabled' }}">
                    <a class="page-link" href="{{ path('admin_attendance_index', app.request.query.all|merge({'page': paginator.nextPage})) }}">Proxima</a>
                </li>
            </ul>
        </nav>
    {% endif %}
{% endblock %}

{% block sidebar %}{% endblock %}
