{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard de Atendimentos{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Dashboard de Atendimentos</h1>
            <p class="text-body-secondary mb-0">Indicadores consolidados das conversas importadas do Chatwoot.</p>
        </div>
        <a class="btn btn-outline-primary" href="{{ path('admin_attendance_index') }}">Lista de protocolos</a>
    </div>

    <div class="row g-3 mb-4">
        {% set kpis = [
            {'label': 'Total recebido', 'value': attendance.total, 'class': 'bg-light'},
            {'label': 'Abertas', 'value': attendance.open, 'class': 'bg-light'},
            {'label': 'Pendentes', 'value': attendance.pending, 'class': 'bg-warning'},
            {'label': 'Resolvidas', 'value': attendance.resolved, 'class': 'bg-success text-white'},
            {'label': 'Protocolos gerados', 'value': attendance.protocols, 'class': 'bg-primary text-white'}
        ] %}

        {% for kpi in kpis %}
            <div class="col-md-4 col-lg">
                <div class="card {{ kpi.class }}">
                    <div class="card-body p-3">
                        <h2 class="h6 text-uppercase small mb-1">{{ kpi.label }}</h2>
                        <p class="fs-3 mb-0">{{ kpi.value }}</p>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <div class="row g-3">
        {% set groups = [
            {'title': 'Por canal', 'items': attendance.byChannel},
            {'title': 'Por etiqueta', 'items': attendance.byLabel},
            {'title': 'Por time', 'items': attendance.byTeam},
            {'title': 'Por agente', 'items': attendance.byAgent},
            {'title': 'Por prioridade', 'items': attendance.byPriority},
            {'title': 'Por status', 'items': attendance.byStatus}
        ] %}

        {% for group in groups %}
            <div class="col-lg-6">
                <div class="card h-100">
                    <div class="card-header">{{ group.title }}</div>
                    <div class="table-responsive">
                        <table class="table table-sm mb-0 align-middle">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in group.items|slice(0, 10) %}
                                    <tr>
                                        <td>{{ item.label }}</td>
                                        <td class="text-end">{{ item.total }}</td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="2" class="text-body-secondary">Sem dados.</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block sidebar %}{% endblock %}
