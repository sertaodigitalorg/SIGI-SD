{% extends 'admin/layout.html.twig' %}

{% block title %}Gerenciar Papéis{% endblock %}

{% block main %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Gerenciar Papéis</h1>
            <p class="text-body-secondary mb-0">Atualize os papéis do vínculo institucional.</p>
        </div>
        <a class="btn btn-outline-secondary" href="{{ path('admin_person_show', {'id': personOrganization.person.id}) }}">Voltar</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">Adicionar novo papel</h2>
                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-12">{{ form_row(form.role) }}</div>
                            <div class="col-md-6">{{ form_row(form.startDate) }}</div>
                            <div class="col-md-6">{{ form_row(form.endDate) }}</div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button class="btn btn-primary">Adicionar papel</button>
                            <a class="btn btn-outline-secondary" href="{{ path('admin_person_show', {'id': personOrganization.person.id}) }}">Cancelar</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="h5 mb-1">Papéis vinculados</h2>
                            <p class="text-body-secondary mb-0">{{ personOrganization.organization.legalName }}</p>
                        </div>
                    </div>

                    {% if personOrganization.personOrganizationRoles is empty %}
                        <p class="text-body-secondary mb-0">Nenhum papel registrado para este vínculo.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Papel</th>
                                        <th>Data de início</th>
                                        <th>Data de fim</th>
                                        <th>Ações</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for relationRole in personOrganization.personOrganizationRoles %}
                                        <tr>
                                            <td>{{ relationRole.role ? relationRole.role.name : 'Sem papel definido' }}</td>
                                            <td>{{ relationRole.startDate ? relationRole.startDate|date('d/m/Y') : '-' }}</td>
                                            <td>{{ relationRole.endDate ? relationRole.endDate|date('d/m/Y') : '-' }}</td>
                                            <td>
                                                <form method="post" action="{{ path('admin_person_organization_role_delete', {'id': personOrganization.id, 'roleId': relationRole.id}) }}" onsubmit="return confirm('Remover este papel do vínculo?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_person_organization_role' ~ relationRole.id) }}">
                                                    <button class="btn btn-sm btn-outline-danger">Remover</button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
