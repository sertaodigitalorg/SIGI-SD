{% if person.recentInteractions is empty %}
    <div class="alert alert-info">Nenhuma interação recente encontrada.</div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Pessoa</th>
                    <th>Contato</th>
                    <th>Status</th>
                    <th>Data do Contato</th>
                    <th>Próximo Contato</th>
                    <th>Responsável</th>
                    <th>Respondeu</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for item in person.recentInteractions %}
                    <tr>
                        <td>{{ item.personContact.person.fullName ?: '-' }}</td>
                        <td>{{ item.personContact.contactType.name ~ ' | ' ~ item.personContact.value }}</td>
                        <td>{{ item.interactionStatus ? item.interactionStatus.name : '-' }}</td>
                        <td>{{ item.contactedAt ? item.contactedAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>{{ item.nextContactAt ? item.nextContactAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>{{ item.performedBy ? item.performedBy.fullName : '-' }}</td>
                        <td>{{ item.responseReceived ? 'Sim' : 'Não' }}</td>
                        <td>
                            <a href="{{ path('admin_person_contact_interaction_show', {'id': item.id}) }}" class="btn btn-sm btn-primary">Visualizar</a>
                            {% if item.thread %}
                                <a href="{{ path('admin_person_contact_interaction_respond', {'id': item.id}) }}" class="btn btn-sm btn-secondary ms-1">Continuar conversa</a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
